# Azeer website environment variables.
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* vars are exposed to the browser.

# --- Sanity CMS ---------------------------------------------------------------
# Project id + dataset are public (safe to expose). Find them in your Sanity
# project settings, or run `sanity init`.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Pin the API version (YYYY-MM-DD). Bump deliberately when adopting new APIs.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only token for reading drafts / private datasets (optional, no NEXT_PUBLIC_).
SANITY_API_READ_TOKEN=
