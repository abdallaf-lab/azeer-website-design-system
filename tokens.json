{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Azeer Design System — canonical token source. DTCG format. globals.css and tailwind theme are GENERATED from this file. CLAUDE.md is the operating-rules companion.",
  "$meta": {
    "name": "Azeer",
    "version": "2.1.0",
    "locked": "2026-05-08",
    "stack": "React 19 · Vite 8 · TypeScript · Tailwind v4 · shadcn (CVA + Radix) · lucide-react · Recharts",
    "quality-target": "Intercom-grade — one accent per screen, whisper borders, no shadows on cards"
  },

  "color": {
    "brand": {
      "$description": "Marketing brand book. Used on landing, decks, hero surfaces, brand moments inside product. Single source for the brand palette.",
      "primary":    { "$value": "#7C64FE", "$type": "color", "$description": "Brand purple. Same value across marketing and product." },
      "secondary":  { "$value": "#0A1F44", "$type": "color", "$description": "Navy. Sidebar anchor — same in light AND dark mode." },
      "accent":     { "$value": "#FFC857", "$type": "color", "$description": "Amber — the gold thread. Brand moments only inside product." },
      "neutral":    { "$value": "#2E2E2E", "$type": "color", "$description": "Body text reference (marketing)." },
      "supportive": { "$value": "#F4F4F4", "$type": "color", "$description": "Soft surface (marketing)." }
    },

    "product": {
      "$description": "Product surfaces. ONE purple, used sparingly. Light values are defaults; dark mode overrides live under mode.dark.",

      "primary":         { "$value": "{color.brand.primary}", "$type": "color", "$description": "#7C64FE. Primary CTA (one per screen), active nav, focus ring, selected state." },
      "primary-hover":   { "$value": "#6B53E5", "$type": "color" },
      "primary-fg":      { "$value": "#FFFFFF", "$type": "color" },
      "primary-muted":   { "$value": "#EFEBFF", "$type": "color", "$description": "Lavender hover/selected surface tint." },

      "secondary":       { "$value": "{color.brand.secondary}", "$type": "color", "$description": "Sidebar background. Same in both modes — anchor never tints." },
      "secondary-hover": { "$value": "#102954", "$type": "color" },
      "secondary-fg":    { "$value": "#FFFFFF", "$type": "color" },
      "secondary-fg-muted": { "$value": "rgba(255, 255, 255, 0.65)", "$type": "color", "$description": "Inactive sidebar item label." },

      "accent":          { "$value": "{color.brand.accent}", "$type": "color", "$description": "Amber. Brand moments only — NEVER on a screen that already uses primary purple as accent." },
      "accent-soft":     { "$value": "#FFF4DA", "$type": "color" },
      "accent-fg":       { "$value": "#2E2E2E", "$type": "color" },

      "background":      { "$value": "#FAFAFA", "$type": "color", "$description": "Tailwind zinc-50. Page surface in light mode." },
      "surface":         { "$value": "#FFFFFF", "$type": "color", "$description": "Cards, popovers, inputs in light mode." },
      "muted":           { "$value": "#F4F4F5", "$type": "color", "$description": "Tailwind zinc-100. Subtle surface variation." },

      "border":          { "$value": "#E4E4E7", "$type": "color", "$description": "Tailwind zinc-200. Whisper border on cards. Never a shadow." },
      "input-border":    { "$value": "#D4D4D8", "$type": "color", "$description": "Tailwind zinc-300. Slightly stronger for input affordance." },
      "ring":            { "$value": "{color.product.primary}", "$type": "color" },

      "foreground":         { "$value": "#18181B", "$type": "color", "$description": "Tailwind zinc-900. Primary text." },
      "foreground-muted":   { "$value": "#71717A", "$type": "color", "$description": "Tailwind zinc-500. Helper, label, secondary text." },
      "foreground-subtle":  { "$value": "#A1A1AA", "$type": "color", "$description": "Tailwind zinc-400. Empty-state icons, placeholders, loading spinners." }
    },

    "semantic": {
      "$description": "Status colors — independent scale. Never reuses brand or accent.",
      "success":             { "$value": "#16A34A", "$type": "color" },
      "success-muted":       { "$value": "#DCFCE7", "$type": "color" },
      "warning":             { "$value": "#EA580C", "$type": "color", "$description": "Orange, NOT amber. The brand accent must never be a warning." },
      "warning-muted":       { "$value": "#FFEDD5", "$type": "color" },
      "destructive":         { "$value": "#DC2626", "$type": "color" },
      "destructive-muted":   { "$value": "#FEE2E2", "$type": "color" },
      "info":                { "$value": "#2563EB", "$type": "color" },
      "info-muted":          { "$value": "#DBEAFE", "$type": "color" }
    },

    "channel": {
      "$description": "Channel marks. Each channel owns its color.",
      "whatsapp":    { "$value": "#25D366", "$type": "color" },
      "voice":       { "$value": "{color.product.primary}", "$type": "color", "$description": "Voice IS Azeer. The single point where channel and brand merge." },
      "sms":         { "$value": "#8A8F98", "$type": "color" },
      "email":       { "$value": "#EA4335", "$type": "color" },
      "instagram":   { "$value": "#E1306C", "$type": "color" },
      "messenger":   { "$value": "#0084FF", "$type": "color" },
      "telegram":    { "$value": "#229ED9", "$type": "color" },
      "webchat":     { "$value": "#0F1011", "$type": "color" },
      "rcs":         { "$value": "#1A73E8", "$type": "color" }
    },

    "voice": {
      "$description": "Call-state colors.",
      "recording-dot": { "$value": "{color.semantic.destructive}", "$type": "color" },
      "on-call":       { "$value": "{color.semantic.success}",     "$type": "color" },
      "ringing":       { "$value": "{color.semantic.warning}",     "$type": "color" }
    },

    "chart": {
      "$description": "Five chart types only (bar, line, donut, sparkline, heatmap). Recharts only. Brand purple for primary series, zinc-400 for secondary.",
      "library":      { "$value": "recharts", "$type": "string" },
      "allowed":      { "$value": ["bar", "line", "donut", "sparkline", "heatmap"], "$type": "array" },
      "series-1":     { "$value": "{color.product.primary}",          "$type": "color", "$description": "Primary series — brand purple." },
      "series-2":     { "$value": "{color.product.foreground-subtle}", "$type": "color", "$description": "Secondary series — zinc-400." },
      "series-3":     { "$value": "{color.brand.accent}",              "$type": "color", "$description": "Amber gold metric — exception to the 'amber not in chrome' rule, because charts are content." },
      "series-4":     { "$value": "#0EA5E9", "$type": "color" },
      "series-5":     { "$value": "#14B8A6", "$type": "color" }
    },

    "tenant": {
      "$description": "Profile B (consumer booking) — tenant brand override slot.",
      "primary":    { "$value": "{color.product.primary}", "$type": "color" },
      "primary-fg": { "$value": "{color.product.primary-fg}", "$type": "color" }
    }
  },

  "mode": {
    "dark": {
      "$description": "Profile A (Agent Console) dark mode overrides. Profile B is light-only.",
      "color": {
        "product": {
          "primary":            "#9B85FF",
          "primary-hover":      "#B19EFF",
          "primary-fg":         "#0A0A0A",
          "primary-muted":      "#1F1A3A",

          "secondary":          "#0A1F44",
          "secondary-hover":    "#102954",
          "secondary-fg":       "#FFFFFF",

          "accent":             "#FFC857",
          "accent-soft":        "#3D2D0F",
          "accent-fg":          "#FFC857",

          "background":         "#18181B",
          "surface":            "#09090B",
          "muted":              "#27272A",

          "border":             "#27272A",
          "input-border":       "#3F3F46",
          "ring":               "#9B85FF",

          "foreground":         "#FAFAFA",
          "foreground-muted":   "#A1A1AA",
          "foreground-subtle":  "#71717A"
        },
        "semantic": {
          "success":     "#22C55E",
          "warning":     "#F97316",
          "destructive": "#EF4444",
          "info":        "#3B82F6"
        },
        "voice": {
          "recording-dot": "#EF4444",
          "on-call":       "#22C55E",
          "ringing":       "#F97316"
        }
      }
    }
  },

  "spacing": {
    "$description": "Strict 4px scale. Anything off-scale is a mistake.",
    "0":  { "$value": "0px",  "$type": "dimension" },
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },

  "radius": {
    "$description": "Three radii + full. 10px, 14px, 16px, 20px+ are FORBIDDEN.",
    "sm":   { "$value": "6px",    "$type": "dimension", "$description": "Inputs, dense list rows, small chips." },
    "md":   { "$value": "8px",    "$type": "dimension", "$description": "Cards, buttons — the operator-grade default." },
    "lg":   { "$value": "12px",   "$type": "dimension", "$description": "Modals, large dialogs only." },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, status dots, avatars." }
  },

  "size": {
    "$description": "Control heights.",
    "xs": { "$value": "24px", "$type": "dimension" },
    "sm": { "$value": "28px", "$type": "dimension" },
    "md": { "$value": "32px", "$type": "dimension" },
    "lg": { "$value": "36px", "$type": "dimension" },
    "xl": { "$value": "44px", "$type": "dimension", "$description": "Mobile minimum touch target." }
  },

  "typography": {
    "$description": "IBM Plex Sans (Latin) + IBM Plex Sans Arabic (Arabic). Self-hosted via Fontsource in production. Three weights only.",
    "family": {
      "sans":   { "$value": "'IBM Plex Sans', 'IBM Plex Sans Arabic', system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "arabic": { "$value": "'IBM Plex Sans Arabic', 'IBM Plex Sans', system-ui, sans-serif",                 "$type": "fontFamily" },
      "mono":   { "$value": "'IBM Plex Mono', ui-monospace, Menlo, monospace",                                "$type": "fontFamily" }
    },
    "weight": {
      "$description": "Three weights. NO 700, NO 300, NO 800. Use size + color for emphasis instead of bold.",
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" }
    },
    "size": {
      "display":  { "$value": "30px", "$type": "dimension", "$description": "Marketing hero only — never inside product chrome." },
      "h1":       { "$value": "24px", "$type": "dimension" },
      "h2":       { "$value": "20px", "$type": "dimension" },
      "h3":       { "$value": "16px", "$type": "dimension" },
      "kpi":      { "$value": "30px", "$type": "dimension", "$description": "KPI tile number — Tailwind 3xl." },
      "body":     { "$value": "14px", "$type": "dimension", "$description": "Default body. Operator-grade density." },
      "body-sm":  { "$value": "13px", "$type": "dimension" },
      "label":    { "$value": "13px", "$type": "dimension" },
      "caption":  { "$value": "12px", "$type": "dimension" },
      "micro":    { "$value": "11px", "$type": "dimension" }
    },
    "line-height": {
      "tight":   { "$value": 1.2, "$type": "number" },
      "normal":  { "$value": 1.5, "$type": "number" },
      "relaxed": { "$value": 1.6, "$type": "number" }
    },
    "letter-spacing": {
      "tight":  { "$value": "-0.02em", "$type": "dimension" },
      "snug":   { "$value": "-0.01em", "$type": "dimension" },
      "normal": { "$value": "0",       "$type": "dimension" },
      "wide":   { "$value": "0.04em",  "$type": "dimension" }
    }
  },

  "shadow": {
    "$description": "No shadows on cards. Reserved for elevated objects only — popover, dropdown, modal, drawer, call bar.",
    "none": { "$value": "none", "$type": "shadow" },
    "sm":   { "$value": "0 1px 2px 0 rgba(10, 31, 68, 0.06)",                                                        "$type": "shadow", "$description": "Popovers, dropdowns." },
    "md":   { "$value": "0 4px 8px -2px rgba(10, 31, 68, 0.10), 0 2px 4px -2px rgba(10, 31, 68, 0.06)",              "$type": "shadow", "$description": "Toasts, floating call bar." },
    "lg":   { "$value": "0 12px 24px -6px rgba(10, 31, 68, 0.12), 0 6px 8px -4px rgba(10, 31, 68, 0.08)",            "$type": "shadow", "$description": "Modals, drawers." }
  },

  "motion": {
    "$description": "Three durations, one curve. AI-enforceable simplicity.",
    "duration": {
      "fast":   { "$value": "100ms", "$type": "duration" },
      "normal": { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "400ms", "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" }
    }
  },

  "z-index": {
    "sidebar":  { "$value": 10, "$type": "number" },
    "panel":    { "$value": 20, "$type": "number" },
    "callbar":  { "$value": 25, "$type": "number" },
    "modal":    { "$value": 30, "$type": "number" },
    "toast":    { "$value": 40, "$type": "number" },
    "tooltip":  { "$value": 50, "$type": "number" }
  },

  "breakpoint": {
    "sm": { "$value": "640px",  "$type": "dimension" },
    "md": { "$value": "768px",  "$type": "dimension" },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension", "$description": "Primary sidebar collapses to icon-only below this." }
  }
}
