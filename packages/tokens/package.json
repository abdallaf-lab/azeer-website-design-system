{
  "name": "@azeer/tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Azeer Design System tokens — Tailwind v4 CSS-first @theme + typed TS lookups",
  "type": "module",
  "sideEffects": ["./src/tokens.css"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["src"],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tw-animate-css": "^1.2.0"
  },
  "devDependencies": {
    "@azeer/config-eslint": "workspace:*",
    "@azeer/config-tsconfig": "workspace:*",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3"
  }
}
